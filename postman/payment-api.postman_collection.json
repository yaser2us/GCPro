                  "        pm.collectionVariables.set('receipt_id', response.receiptId);",
                  "        console.log('\u2705 Receipt Issued:', response.receiptId);",
                  "        console.log('   Receipt No:', response.receiptNo);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
