                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    console.log('\u2705 Payment Method Deleted:', pm.collectionVariables.get('payment_method_id'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{user_id}}",
                "type": "text"
              },
              {
                "key": "X-User-Role",
                "value": "{{user_role}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/payment-method/{{payment_method_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "payment-method",
                "{{payment_method_id}}"
              ]
            },
            "description": "Soft-deletes a payment method. Requires Idempotency-Key header (auto-generated)."
          },
          "response": []
        }
      ]
    },
