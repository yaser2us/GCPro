    {
      "key": "receipt_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Payment Methods",
      "description": "Manage saved payment methods (cards, bank accounts, eWallets)",
      "item": [
        {
          "name": "1.1 Create Payment Method",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.paymentMethodId) {",
                  "        pm.collectionVariables.set('payment_method_id', response.paymentMethodId);",
                  "        console.log('✅ Payment Method Created:', response.paymentMethodId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": {{account_id}},\n  \"personId\": {{person_id}},\n  \"provider\": \"stripe\",\n  \"methodType\": \"card\",\n  \"providerCustomerRef\": \"cus_test123\",\n  \"providerMethodRef\": \"pm_test456\",\n  \"brand\": \"visa\",\n  \"last4\": \"4242\",\n  \"expMm\": \"12\",\n  \"expYyyy\": \"2027\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payment-method",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payment-method"]
            },
            "description": "Creates a saved payment method. Requires Idempotency-Key header (auto-generated)."
          },
          "response": []
        },
        {
          "name": "1.2 Delete Payment Method",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    console.log('✅ Payment Method Deleted:', pm.collectionVariables.get('payment_method_id'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/payment-method/{{payment_method_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payment-method", "{{payment_method_id}}"]
            },
            "description": "Soft-deletes a payment method. Requires Idempotency-Key header (auto-generated)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Payment Intent Lifecycle",
      "description": "Full payment intent lifecycle: create → confirm → succeed / fail / cancel",
      "item": [
        {
          "name": "2.1 Create Payment Intent",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.intentId) {",
                  "        pm.collectionVariables.set('intent_id', response.intentId);",
                  "        console.log('✅ Intent Created:', response.intentId);",
                  "    }",
                  "    if (response.intentKey) {",
                  "        pm.collectionVariables.set('intent_key', response.intentKey);",
                  "        console.log('   Intent Key:', response.intentKey);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": {{account_id}},\n  \"personId\": {{person_id}},\n  \"intentType\": \"payment\",\n  \"amount\": 150.00,\n  \"currency\": \"MYR\",\n  \"purposeCode\": \"policy_premium\",\n  \"refType\": \"policy\",\n  \"refId\": \"POL-001\",\n  \"paymentMethodId\": {{payment_method_id}},\n  \"provider\": \"stripe\",\n  \"returnUrl\": \"https://app.example.com/payment/return\",\n  \"callbackUrl\": \"https://app.example.com/payment/callback\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payment-intent",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payment-intent"]
            },
            "description": "Creates a payment intent. Status starts as 'created'. Saves intent_id and intent_key to collection variables."
          },
          "response": []
        },
        {
          "name": "2.2 Confirm Payment Intent",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    console.log('✅ Intent Confirmed - Status:', response.status);",
                  "    if (response.redirectUrl) {",
                  "        console.log('   Redirect URL:', response.redirectUrl);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"stripe\",\n  \"paymentMethodId\": {{payment_method_id}},\n  \"returnUrl\": \"https://app.example.com/payment/return\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payment-intent/{{intent_id}}/confirm",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payment-intent", "{{intent_id}}", "confirm"]
            },
            "description": "Confirms a payment intent with the provider. Status transitions: created → processing. Creates a payment attempt."
          },
          "response": []
        },
        {
          "name": "2.3 Cancel Payment Intent",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    console.log('✅ Intent Cancelled - Status:', response.status);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payment-intent/{{intent_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payment-intent", "{{intent_id}}", "cancel"]
            },
            "description": "Cancels a payment intent. Valid from 'created' or 'processing' status."
          },
          "response": []
        },
        {
          "name": "2.4 Mark Intent Succeeded (Admin)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    console.log('✅ Intent Marked Succeeded:', response.intentId);",
                  "    console.log('   Succeeded At:', response.succeededAt);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{admin_user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{admin_user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payment-intent/{{intent_id}}/mark-succeeded",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payment-intent", "{{intent_id}}", "mark-succeeded"]
            },
            "description": "Admin-only. Marks a payment intent as succeeded. Requires payment:admin permission. Triggers PAYMENT_SUCCEEDED event."
          },
          "response": []
        },
        {
          "name": "2.5 Mark Intent Failed (Admin)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    console.log('✅ Intent Marked Failed:', response.intentId);",
                  "    console.log('   Failure Code:', response.failureCode);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{admin_user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{admin_user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"failureCode\": \"insufficient_funds\",\n  \"failureMessage\": \"Card declined due to insufficient funds\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/payment-intent/{{intent_id}}/mark-failed",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "payment-intent", "{{intent_id}}", "mark-failed"]
            },
            "description": "Admin-only. Marks a payment intent as failed. Requires payment:admin permission."
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Receipts (Admin)",
      "description": "Issue and void payment receipts. Requires payment:admin permission.",
      "item": [
        {
          "name": "3.1 Issue Receipt",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.receiptId) {",
                  "        pm.collectionVariables.set('receipt_id', response.receiptId);",
                  "        console.log('✅ Receipt Issued:', response.receiptId);",
                  "        console.log('   Receipt No:', response.receiptNo);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{admin_user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{admin_user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"intentId\": {{intent_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/receipt",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "receipt"]
            },
            "description": "Admin-only. Issues a receipt for a succeeded payment intent. Saves receipt_id to collection variables."
          },
          "response": []
        },
        {
          "name": "3.2 Void Receipt",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    console.log('✅ Receipt Voided:', response.receiptId);",
                  "    console.log('   Voided At:', response.voidedAt);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{admin_user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{admin_user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/receipt/{{receipt_id}}/void",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "receipt", "{{receipt_id}}", "void"]
            },
            "description": "Admin-only. Voids an issued receipt. Requires payment:admin permission."
          },
          "response": []
        }
      ]
    },
    {
      "name": "4. Webhooks",
      "description": "Payment provider webhook ingestion endpoints",
      "item": [
        {
          "name": "4.1 Receive Stripe Webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    console.log('✅ Webhook Received:', response.webhookId);",
                  "    console.log('   Status:', response.status);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" },
              { "key": "stripe-signature", "value": "t=1234567890,v1=abc123signature", "type": "text" },
              { "key": "stripe-event-id", "value": "evt_test_123456", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_123456\",\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_test_789\",\n      \"status\": \"succeeded\",\n      \"amount\": 15000,\n      \"currency\": \"myr\",\n      \"metadata\": {\n        \"intent_key\": \"{{intent_key}}\"\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/webhook/stripe",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "webhook", "stripe"]
            },
            "description": "Simulates a Stripe webhook. Signature is read from stripe-signature header. Provider event ID from stripe-event-id header."
          },
          "response": []
        },
        {
          "name": "4.2 Receive FPX Webhook",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "    key: 'Idempotency-Key',",
                  "    value: pm.variables.replaceIn('{{$guid}}'),",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    console.log('✅ FPX Webhook Received:', response.webhookId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" },
              { "key": "x-signature", "value": "fpx-hmac-signature-here", "type": "text" },
              { "key": "x-event-id", "value": "fpx_evt_001", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"fpx_evt_001\",\n  \"event\": \"payment.success\",\n  \"fpx_txn_id\": \"FPX20240101001\",\n  \"amount\": \"150.00\",\n  \"currency\": \"MYR\",\n  \"status\": \"success\",\n  \"ref_id\": \"{{intent_key}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/webhook/fpx",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "webhook", "fpx"]
            },
            "description": "Simulates an FPX webhook callback."
          },
          "response": []
        }
      ]
    }
  ]
}
