                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id", "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
