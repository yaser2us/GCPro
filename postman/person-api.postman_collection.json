				{
					"name": "3. Get Complete Person Info",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/persons/{{person_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "persons", "{{person_id}}"]
						}
					},
					"response": []
