						"body": {
							"mode": "raw",
							"raw": "{\n  \"to_person_id\": \"3\",\n  \"relation_type\": \"child\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/persons/{{person_id}}/relationships",
							"host": ["{{base_url}}"],
							"path": ["v1", "persons", "{{person_id}}", "relationships"]
						}
					},
					"response": []
				},
				{
					"name": "List Relationships",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/persons/{{person_id}}/relationships",
							"host": ["{{base_url}}"],
							"path": ["v1", "persons", "{{person_id}}", "relationships"]
						},
						"description": "List all relationships for a person"
					},
					"response": []
				}
			],
			"description": "Relationship management (family, dependents, etc.)"
		},
		{
			"name": "Complete Workflow",
			"item": [
				{
					"name": "1. Create Person",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"person_id\", jsonData.person_id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"type\": \"individual\",\n  \"full_name\": \"Alice Johnson\",\n  \"dob\": \"1985-08-22\",\n  \"gender\": \"female\",\n  \"nationality\": \"US\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/persons",
							"host": ["{{base_url}}"],
							"path": ["v1", "persons"]
						}
					},
					"response": []
				},
				{
					"name": "2. Add Passport",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"passport_id\", jsonData.identity_id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id_type\": \"passport\",\n  \"id_no\": \"AB9876543\",\n  \"country\": \"US\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/persons/{{person_id}}/identities",
							"host": ["{{base_url}}"],
							"path": ["v1", "persons", "{{person_id}}", "identities"]
