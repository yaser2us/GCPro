									"pm.environment.set(\"relationship_id\", jsonData.relationship_id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"to_person_id\": \"2\",\n  \"relation_type\": \"spouse\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/persons/{{person_id}}/relationships",
							"host": ["{{base_url}}"],
							"path": ["v1", "persons", "{{person_id}}", "relationships"]
						},
						"description": "Create relationship between persons\n\nIdempotency: Via UNIQUE(person_id, related_person_id, relationship_type)"
					},
					"response": []
