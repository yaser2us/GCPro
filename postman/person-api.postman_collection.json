							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"to_person_id\": \"3\",\n  \"relation_type\": \"child\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/persons/{{person_id}}/relationships",
							"host": ["{{base_url}}"],
							"path": ["v1", "persons", "{{person_id}}", "relationships"]
						}
					},
					"response": []
				},
				{
					"name": "List Relationships",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/persons/{{person_id}}/relationships",
							"host": ["{{base_url}}"],
							"path": ["v1", "persons", "{{person_id}}", "relationships"]
						},
						"description": "List all relationships for a person"
					},
					"response": []
				}
			],
			"description": "Relationship management (family, dependents, etc.)"
		},
		{
