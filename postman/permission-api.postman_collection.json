		{
			"name": "Role Permissions",
			"item": [
				{
					"name": "Assign Permission to Role",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"permission_id\": \"{{permission_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/roles/{{role_id}}/permissions",
							"host": ["{{base_url}}"],
							"path": ["v1", "roles", "{{role_id}}", "permissions"]
						},
						"description": "Assign permission to role\n\nIdempotency: Via UNIQUE(role_id, permission_id)"
					},
					"response": []
				},
				{
					"name": "Revoke Permission from Role",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/roles/{{role_id}}/permissions/{{permission_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "roles", "{{role_id}}", "permissions", "{{permission_id}}"]
						},
						"description": "Revoke permission from role"
					},
					"response": []
				},
				{
					"name": "List Role Permissions",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/v1/roles/{{role_id}}/permissions",
							"host": ["{{base_url}}"],
							"path": ["v1", "roles", "{{role_id}}", "permissions"]
						},
						"description": "List all permissions assigned to role"
					},
					"response": []
				}
			],
			"description": "Role permission assignments"
		},
		{
			"name": "Complete Workflow",
			"item": [
				{
					"name": "1. Create Admin Role",
					"event": [
