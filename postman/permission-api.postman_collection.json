							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"code\": \"super_admin\",\n  \"name\": \"Super Administrator\",\n  \"description\": \"Full system administrator with all permissions\",\n  \"status\": \"active\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/roles",
							"host": ["{{base_url}}"],
							"path": ["v1", "roles"]
