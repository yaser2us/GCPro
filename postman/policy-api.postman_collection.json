    {
      "name": "5. Deposit Requirement (M1)",
      "description": "M1 — Deposit Capacity Formula Enforcement\nFormula: deposit_capacity = monthly_max_cap × multiplier; thresholds from pcts\nRate re-derived from policy_package_rate on each evaluate call.",
      "item": [
        {
          "name": "M1.1 — Get Deposit Status",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-User-Id",   "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/policy/{{policy_id}}/deposit",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "policy", "{{policy_id}}", "deposit"]
            },
            "description": "M1 — Read current deposit requirement status.\nReturns stored thresholds + status without recalculating."
          },
          "response": []
        },
        {
          "name": "M1.2 — Evaluate Deposit (balance OK)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has deposit_capacity', function () { pm.expect(pm.response.json().deposit_capacity).to.be.a('number'); });",
                  "pm.test('Status is ok or warning', function () {",
                  "  pm.expect(['ok','warning','urgent','critical']).to.include(pm.response.json().status);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",   "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_balance\": 8000.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/policy/{{policy_id}}/deposit/evaluate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "policy", "{{policy_id}}", "deposit", "evaluate"]
            },
            "description": "M1 — Re-derives monthly_max_cap from policy_package_rate, recomputes all thresholds, evaluates balance.\n\nFormula:\n  deposit_capacity = monthly_max_cap × deposit_capacity_multiplier\n  min_required     = deposit_capacity × min_deposit_pct\n  warning_amount   = deposit_capacity × warning_pct\n\nWith monthly_max_cap=5000, multiplier=2.0: deposit_capacity=10000, min_required=5000\nBalance 8000 → status=warning"
          },
          "response": []
        },
        {
          "name": "M1.3 — Evaluate Deposit (balance critical)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",   "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_balance\": 1000.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/policy/{{policy_id}}/deposit/evaluate",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "policy", "{{policy_id}}", "deposit", "evaluate"]
            },
            "description": "M1 — Balance well below min_required → expect status=critical"
          },
          "response": []
        }
      ]
    },
