    {
      "name": "4. Billing & Installments (C7)",
      "item": [
        {
          "name": "C7.1 — Create Split Billing Plan (50/50)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.test('installment_count is 2', function () { pm.expect(json.installment_count).to.eql(2); });",
                  "pm.test('billing_type is split', function () { pm.expect(json.billing_type).to.eql('split'); });",
                  "if (json.billing_plan_id) pm.collectionVariables.set('billing_plan_id', json.billing_plan_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id",   "value": "{{user_id}}", "type": "text" },
              { "key": "X-User-Role", "value": "{{user_role}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"billing_type\": \"split\",\n  \"total_amount\": 9600.00,\n  \"idempotency_key\": \"billing-split-{{$guid}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/policy/{{policy_id}}/billing-plan/create",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "policy", "{{policy_id}}", "billing-plan", "create"]
            },
            "description": "C7 — 50/50 split payment.\n\nCreates 2 installments:\n- No.1: 4800.00, due now\n- No.2: 4800.00, due in 30 days\n\nPolicy activates after installment_no=1 paid."
          },
          "response": []
        },
        {
          "name": "C7.2 — Create Full Upfront Billing Plan",
          "request": {
