    {
      "name": "📋 Step 1: Create Mission Definition",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"✅ Mission created successfully\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Mission ID captured\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('mission_definition_id');",
              "    pm.collectionVariables.set(\"mission_id\", jsonData.mission_definition_id);",
              "    ",
              "    console.log(\"\\n🎯 MISSION CREATED\");",
              "    console.log(\"Mission ID: \" + jsonData.mission_definition_id);",
              "    console.log(\"Reward: 50 COIN\");",
              "    console.log(\"Status: \" + jsonData.status);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
