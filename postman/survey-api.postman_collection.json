{
	"info": {
		"_postman_id": "survey-api-collection",
		"name": "Survey API",
		"description": "Complete API collection for Survey Plugin\n\nBased on: specs/survey/survey.pillar.v2.yml\n\nAll write operations require Idempotency-Key header.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
