	"item": [
		{
			"name": "Survey",
			"item": [
				{
					"name": "Create Survey",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('survey_id', response.survey_id);",
									"    pm.test('Survey created successfully', function() {",
									"        pm.expect(response.status).to.eql('active');",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Idempotency-Key",
								"value": "create-survey-{{$randomUUID}}",
								"type": "text"
							},
							{
								"key": "X-User-Id",
								"value": "{{user_id}}",
								"type": "text"
							},
							{
								"key": "X-User-Role",
								"value": "ADMIN",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"code\": \"nps-2024-q1\",\n  \"name\": \"Net Promoter Score Q1 2024\",\n  \"description\": \"Quarterly NPS survey for customer satisfaction\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/v1/surveys",
							"host": [
								"{{base_url}}"
							],
