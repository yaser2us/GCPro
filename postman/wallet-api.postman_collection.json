{
  "info": {
    "name": "Wallet API",
    "description": "Complete wallet management API with double-entry accounting\n\nBased on: specs/wallet/wallet.pillar.v2.yml\n\nFeatures:\n- Account creation\n- Wallet management\n- Deposit/Withdraw operations\n- Balance tracking\n- Transaction history\n- Double-entry ledger\n\nEvent Integration:\n- Automatically credits wallet on mission completion\n- Listens to MISSION_REWARD_GRANTED events",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
