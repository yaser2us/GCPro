      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "admin_user_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "test_user_id",
      "value": "2",
      "type": "string"
    },
