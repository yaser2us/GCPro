      "description": "Withdraw operations to deduct funds from wallets.\n\nWithdraw Types:\n- manual_withdrawal: Admin-initiated withdrawals\n- redemption: User spending coins on features\n- transfer_out: Transfer to another account\n- refund_reversal: Reversing a previous refund"
    },
    {
      "name": "5. Balance & Transactions",
      "item": [
        {
          "name": "Get Balance",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has balance fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('wallet_id');",
                  "    pm.expect(jsonData).to.have.property('available_amount');",
                  "    pm.expect(jsonData).to.have.property('held_amount');",
                  "    pm.expect(jsonData).to.have.property('total_amount');",
                  "    pm.expect(jsonData).to.have.property('currency');",
                  "    pm.expect(jsonData).to.have.property('as_of');",
                  "    ",
                  "    console.log(\"============ WALLET BALANCE ============\");",
                  "    console.log(\"Available: \" + jsonData.available_amount + \" \" + jsonData.currency);",
                  "    console.log(\"Held:      \" + jsonData.held_amount + \" \" + jsonData.currency);",
                  "    console.log(\"Total:     \" + jsonData.total_amount + \" \" + jsonData.currency);",
                  "    console.log(\"As of:     \" + jsonData.as_of);",
                  "    console.log(\"=======================================\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{test_user_id}}"
              },
              {
                "key": "X-User-Role",
                "value": "USER"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/wallets/{{wallet_id}}/balance",
              "host": ["{{base_url}}"],
              "path": ["v1", "wallets", "{{wallet_id}}", "balance"]
            },
            "description": "Retrieves the current wallet balance.\n\n**Spec:** specs/wallet/wallet.pillar.v2.yml lines 923-950\n\n**Permissions:** wallet:read\n\n**Response:**\n- available_amount: Can be spent immediately\n- held_amount: Locked/pending transactions\n- total_amount: available + held\n- as_of: Timestamp of balance snapshot\n\n**Performance:**\nBalance is retrieved from wallet_balance_snapshot (single row), not calculated from ledger entries. This ensures fast reads."
          },
          "response": []
        },
        {
          "name": "Get Transactions (All)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has items array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('items');",
                  "    pm.expect(jsonData.items).to.be.an('array');",
                  "    ",
                  "    console.log(\"============ TRANSACTIONS ============\");",
                  "    console.log(\"Total transactions: \" + jsonData.items.length);",
                  "    ",
                  "    jsonData.items.forEach(function(txn, index) {",
                  "        console.log(\"\\nTransaction #\" + (index + 1));",
                  "        console.log(\"  ID: \" + txn.id);",
                  "        console.log(\"  Type: \" + txn.type);",
                  "        console.log(\"  Status: \" + txn.status);",
                  "        console.log(\"  Occurred: \" + txn.occurred_at);",
                  "        if (txn.ref_type) {",
                  "            console.log(\"  Ref: \" + txn.ref_type + \" / \" + txn.ref_id);",
                  "        }",
                  "    });",
                  "    console.log(\"=====================================\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{test_user_id}}"
              },
              {
                "key": "X-User-Role",
                "value": "USER"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/wallets/{{wallet_id}}/transactions?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["v1", "wallets", "{{wallet_id}}", "transactions"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
