			"item": [
				{
					"name": "Create Mission - Success",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-User-Id",
								"value": "{{admin_user_id}}"
							},
							{
								"key": "X-User-Role",
								"value": "ADMIN"
							},
							{
								"key": "Idempotency-Key",
								"value": "create-{{$timestamp}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"code\": \"MISSION_{{$timestamp}}\",\n  \"title\": \"Complete 5 Policy Applications\",\n  \"description\": \"Submit and get approved for 5 policy applications to earn rewards\",\n  \"cadence\": \"one_time\",\n  \"max_per_user\": 1,\n  \"reward_json\": {\n    \"reward_type\": \"FIXED\",\n    \"amount\": 50,\n    \"currency\": \"MYR\"\n  }\n}"
						},
