{
  "info": {
    "name": "Identity API",
    "description": "Postman collection for the Identity pillar — auth (login/logout/me), device tokens, registration tokens, verification status, onboarding progress.\nBased on specs/identity/identity.pillar.v2.yml\nAll endpoints: /v1/identity/",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url",            "value": "http://localhost:3000",       "type": "string" },
    { "key": "admin_user_id",       "value": "1",                           "type": "string" },
    { "key": "admin_user_role",     "value": "admin",                       "type": "string" },
    { "key": "user_user_id",        "value": "2",                           "type": "string" },
    { "key": "user_user_role",      "value": "user",                        "type": "string" },
    { "key": "target_user_id",      "value": "2",                           "type": "string" },
    { "key": "target_account_id",   "value": "2",                           "type": "string" },
    { "key": "target_phone",        "value": "+60123456789",                "type": "string" },
    { "key": "device_token_id",     "value": "",                            "type": "string" },
    { "key": "registration_token_id", "value": "",                          "type": "string" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-inject Idempotency-Key for all POST requests",
          "if (pm.request.method === 'POST' || pm.request.method === 'PUT') {",
          "  const existingKey = pm.request.headers.get('Idempotency-Key');",
          "  if (!existingKey) {",
          "    pm.request.headers.add({",
          "      key: 'Idempotency-Key',",
          "      value: pm.variables.replaceIn('{{$guid}}')",
          "    });",
          "  }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Issue OTP (pre-login — purpose=login)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"purpose\": \"login\",\n  \"channel_type\": \"sms\",\n  \"channel_value\": \"{{target_phone}}\",\n  \"otp_hash\": \"$2b$10$exampleBcryptHashOfOTP123456\",\n  \"expires_at\": \"2099-12-31T23:59:59.000Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/registration-tokens",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "registration-tokens"]
            },
            "description": "Step 1 of login flow: issue an OTP registration token for the user's phone.\n\nFields (from RegistrationTokenIssueDto):\n- purpose: 'login' (required for Login command to find this token)\n- channel_type: 'sms' | 'email' | 'whatsapp'\n- channel_value: phone number or email\n- otp_hash: bcrypt hash of the OTP digits (generated server-side in production)\n- expires_at: ISO 8601 expiry time\n\nNote: 60-second cooldown is enforced per channel_value.\nNote: In production the otp_hash is generated by the server, not the client."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('registration_token_id', json.id);",
                  "  console.log('registration_token_id set to', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Login (OTP verify + session)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"channel_type\": \"sms\",\n  \"channel_value\": \"{{target_phone}}\",\n  \"otp_plain\": \"123456\",\n  \"platform\": \"fcm\",\n  \"device_token\": \"eXaMpLeDeViCeToKeN_FcM_Login_001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/login",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "login"]
            },
            "description": "Unauthenticated. No x-user-id header required.\n\nFields (from LoginDto):\n- channel_type: must match the OTP channel used in step 1.1\n- channel_value: phone number or email (must match a user record)\n- otp_plain: plain OTP digits to verify against stored otp_hash\n- platform: 'fcm' | 'apns' | 'web'\n- device_token: raw push token for this device\n\nResponse: { user, device_token }\nUse device_token.id for subsequent Logout call."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json && json.device_token && json.device_token.id) {",
                  "  pm.collectionVariables.set('device_token_id', json.device_token.id);",
                  "  console.log('device_token_id set to', json.device_token.id);",
                  "}",
                  "if (json && json.user && json.user.id) {",
                  "  pm.collectionVariables.set('user_user_id', json.user.id);",
                  "  console.log('user_user_id set to', json.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Get Current User (GET /me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "x-user-id",   "value": "{{user_user_id}}" },
              { "key": "x-user-role", "value": "{{user_user_role}}" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/identity/me",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "me"]
            },
            "description": "Authenticated (identity:user). Returns the current user's record from the user table.\n\nNo request body. Actor is resolved from x-user-id header.\n\nResponse fields (from User entity):\n- id\n- phone_number\n- email\n- email_verified_at\n- status\n- created_at\n- updated_at"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user id', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.4 Logout (revoke own device token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{user_user_id}}" },
              { "key": "x-user-role", "value": "{{user_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"device_token_id\": {{device_token_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/logout",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "logout"]
            },
            "description": "Authenticated (identity:user). Actor must own the device_token_id.\n\nBody field (from LogoutDto inline — controller @Body('device_token_id')):\n- device_token_id: number — ID of the device token to revoke\n\nGuards:\n- DEVICE_TOKEN_NOT_FOUND\n- DEVICE_TOKEN_NOT_OWNED_BY_USER (user_id mismatch)\n- DEVICE_TOKEN_ALREADY_REVOKED"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json) {",
                  "  pm.test('Device token is revoked', () => pm.expect(json.status).to.equal('revoked'));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Device Tokens (admin)",
      "item": [
        {
          "name": "2.1 Register Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{target_user_id}},\n  \"platform\": \"fcm\",\n  \"token\": \"eXaMpLeDeViCeToKeN_FcM_Admin_001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/device-tokens",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "device-tokens"]
            },
            "description": "Admin command. Requires identity:admin permission.\n\nFields (from DeviceTokenRegisterDto):\n- user_id: number — user to register the device for\n- platform: 'fcm' | 'apns' | 'web'\n- token: raw device push token (max 512 chars)\n\nIdempotency: upsert via UNIQUE(platform, token).\nIf token exists for same user → re-activates.\nIf token exists for different user → DEVICE_TOKEN_OWNED_BY_ANOTHER_USER."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('device_token_id', json.id);",
                  "  console.log('device_token_id set to', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Register Device Token (apns — second device)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{target_user_id}},\n  \"platform\": \"apns\",\n  \"token\": \"eXaMpLeDeViCeToKeN_ApNs_Admin_001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/device-tokens",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "device-tokens"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 Revoke Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/device-tokens/{{device_token_id}}/revoke",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "device-tokens", "{{device_token_id}}", "revoke"]
            },
            "description": "Admin command. Requires identity:admin permission.\n\nPath param:\n- deviceTokenId: number\n\nGuards:\n- DEVICE_TOKEN_NOT_FOUND\n- DEVICE_TOKEN_ALREADY_REVOKED"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json) {",
                  "  pm.test('Device token is revoked', () => pm.expect(json.status).to.equal('revoked'));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Registration Tokens",
      "item": [
        {
          "name": "3.1 Issue Registration Token (registration)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"purpose\": \"registration\",\n  \"channel_type\": \"sms\",\n  \"channel_value\": \"{{target_phone}}\",\n  \"invite_code\": \"GCPRO-INVITE-2026\",\n  \"otp_hash\": \"$2b$10$exampleBcryptHashOfOTP123456\",\n  \"expires_at\": \"2099-12-31T23:59:59.000Z\",\n  \"meta_json\": { \"ip\": \"127.0.0.1\" }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/registration-tokens",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "registration-tokens"]
            },
            "description": "Fields (from RegistrationTokenIssueDto):\n- purpose: 'registration' | 'phone_verify' | 'email_verify' | 'password_reset' | 'login' (optional, defaults to 'registration')\n- channel_type: 'email' | 'sms' | 'whatsapp' (required)\n- channel_value: email address or phone number (required)\n- invite_code: REQUIRED when purpose='registration' — must match an active referral_code with code_type='invite' (seed: GCPRO-INVITE-2026)\n- token: magic-link token (optional)\n- otp_hash: bcrypt hash of OTP digits (optional)\n- expires_at: ISO 8601 datetime (required)\n- meta_json: arbitrary metadata object (optional)\n\nGuards (purpose='registration' only):\n- INVITE_CODE_REQUIRED — invite_code missing\n- INVITE_CODE_INVALID  — invite_code not found or inactive (C2)\n- TERMS_NOT_ACCEPTED   — user exists but hasn't accepted gc:terms (M7)\n- REGISTRATION_TOKEN_COOLDOWN_ACTIVE — pending token issued within last 60s (L6)"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('registration_token_id', json.id);",
                  "  console.log('registration_token_id set to', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Issue Registration Token (email_verify)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"purpose\": \"email_verify\",\n  \"channel_type\": \"email\",\n  \"channel_value\": \"user@example.com\",\n  \"token\": \"magic-link-token-abc123\",\n  \"expires_at\": \"2099-12-31T23:59:59.000Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/registration-tokens",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "registration-tokens"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 Verify Registration Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp_plain\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/registration-tokens/{{registration_token_id}}/verify",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "registration-tokens", "{{registration_token_id}}", "verify"]
            },
            "description": "Fields (from RegistrationTokenVerifyDto):\n- token: magic-link token string (required if otp_plain not provided)\n- otp_plain: plain OTP digits (required if token not provided)\n\nAt least one of token or otp_plain must be provided.\n\nGuards:\n- REGISTRATION_TOKEN_NOT_FOUND\n- REGISTRATION_TOKEN_NOT_PENDING\n- REGISTRATION_TOKEN_EXPIRED\n- REGISTRATION_TOKEN_INVALID"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json) {",
                  "  pm.test('Token is verified', () => pm.expect(json.status).to.equal('verified'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3.4 Consume Registration Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/registration-tokens/{{registration_token_id}}/consume",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "registration-tokens", "{{registration_token_id}}", "consume"]
            },
            "description": "No body. Path param: registrationTokenId.\n\nToken must be in 'verified' status.\n\nGuards:\n- REGISTRATION_TOKEN_NOT_FOUND\n- REGISTRATION_TOKEN_NOT_VERIFIED"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json) {",
                  "  pm.test('Token is consumed', () => pm.expect(json.status).to.equal('consumed'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "3.5 Expire Registration Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/registration-tokens/{{registration_token_id}}/expire",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "registration-tokens", "{{registration_token_id}}", "expire"]
            },
            "description": "Admin force-expire. No body.\n\nToken must be in 'pending' or 'verified' status.\n\nGuards:\n- REGISTRATION_TOKEN_NOT_FOUND\n- REGISTRATION_TOKEN_ALREADY_TERMINAL"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json) {",
                  "  pm.test('Token is expired', () => pm.expect(json.status).to.equal('expired'));",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4. Verification Status",
      "item": [
        {
          "name": "4.1 Upsert Verification Status (kyc → verified)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id",   "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_id\": {{target_account_id}},\n  \"type\": \"kyc\",\n  \"status\": \"verified\",\n  \"meta_json\": { \"provider\": \"ekyc_provider\", \"reference\": \"KYC-2026-001\" }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/identity/verification-status",
              "host": ["{{base_url}}"],
              "path": ["v1", "identity", "verification-status"]
            },
            "description": "Fields (from VerificationStatusUpsertDto):\n- account_id: number (required)\n- type: 'email' | 'phone' | 'kyc' | 'id_document' — verification dimension (required, max 32)\n- status: 'unverified' | 'pending' | 'verified' | 'failed' | 'expired' (required, max 32)\n- meta_json: provider response, reference IDs (optional)\n\nIdempotency: upsert via UNIQUE(account_id, type)."
          },
