				{
					"name": "Start Virus Scan",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"scan_type\": \"antivirus\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/files/{{file_id}}/scan/start",
							"host": ["{{base_url}}"],
							"path": ["v1", "files", "{{file_id}}", "scan", "start"]
						},
						"description": "Initiate virus scan (sets status='scanning')"
					},
					"response": []
				},
