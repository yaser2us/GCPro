								"key": "Idempotency-Key",
								"value": "{{$guid}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"scan_type\": \"antivirus\",\n  \"status\": \"clean\",\n  \"provider\": \"ClamAV\",\n  \"summary\": \"No threats detected\"\n}"
