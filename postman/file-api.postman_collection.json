		{
			"name": "Access Tokens",
			"item": [
				{
					"name": "Generate Access Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"access_token\", jsonData.token);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token_type\": \"download\",\n  \"expires_in_seconds\": 3600,\n  \"max_uses\": 3\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/files/{{file_id}}/tokens",
							"host": ["{{base_url}}"],
							"path": ["v1", "files", "{{file_id}}", "tokens"]
						},
						"description": "Generate temporary access token\n\nExpires in 1 hour, max 3 uses"
					},
					"response": []
				},
				{
					"name": "Generate Unlimited Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token_type\": \"download\",\n  \"expires_in_seconds\": 86400,\n  \"max_uses\": 0\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/files/{{file_id}}/tokens",
							"host": ["{{base_url}}"],
							"path": ["v1", "files", "{{file_id}}", "tokens"]
						},
						"description": "Generate token valid for 24 hours, unlimited uses"
					},
					"response": []
				},
				{
					"name": "Validate Access Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{access_token}}\",\n  \"increment_usage\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/file-tokens/validate",
							"host": ["{{base_url}}"],
							"path": ["v1", "file-tokens", "validate"]
						},
						"description": "Validate token and optionally increment usage counter"
					},
					"response": []
				},
				{
					"name": "Revoke Access Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"token\": \"{{access_token}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/file-tokens/revoke",
							"host": ["{{base_url}}"],
							"path": ["v1", "file-tokens", "revoke"]
						},
						"description": "Revoke access token immediately"
					},
					"response": []
				}
			],
			"description": "Temporary access token management"
		},
