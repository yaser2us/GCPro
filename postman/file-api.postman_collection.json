{
	"info": {
		"_postman_id": "file-api-v1",
		"name": "File API",
		"description": "File Management - Upload, Versioning, Access Control, and Scanning\n\nSource: specs/file/file.pillar.v2.yml",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "File Upload",
			"item": [
				{
					"name": "Create File Upload",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"file_id\", jsonData.file_id);",
									"pm.environment.set(\"file_key\", jsonData.file_key);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"file_key\": \"upload-{{$timestamp}}\",\n  \"owner_account_id\": \"1\",\n  \"owner_person_id\": \"100\",\n  \"owner_type\": \"account\",\n  \"purpose_code\": \"document\",\n  \"visibility\": \"private\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/files",
							"host": ["{{base_url}}"],
							"path": ["v1", "files"]
						},
						"description": "Create file upload record with status='created'\n\nIdempotency: Via UNIQUE(file_key)"
					},
					"response": []
				},
				{
					"name": "Complete File Upload",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"storage_path\": \"uploads/2026/03/document.pdf\",\n  \"original_filename\": \"contract.pdf\",\n  \"content_type\": \"application/pdf\",\n  \"size_bytes\": 1024000,\n  \"checksum_sha256\": \"abc123def456\",\n  \"extension\": \"pdf\",\n  \"storage_etag\": \"etag-12345\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/files/{{file_id}}/complete",
							"host": ["{{base_url}}"],
							"path": ["v1", "files", "{{file_id}}", "complete"]
						},
						"description": "Mark file upload as complete with metadata"
					},
					"response": []
				},
				{
					"name": "Fail File Upload",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"reason\": \"Network timeout during upload\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/files/{{file_id}}/fail",
							"host": ["{{base_url}}"],
							"path": ["v1", "files", "{{file_id}}", "fail"]
						},
						"description": "Mark file upload as failed"
					},
					"response": []
				},
				{
					"name": "Delete File",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"deleted_by_user_id\": 42\n}"
						},
						"url": {
							"raw": "{{base_url}}/v1/files/{{file_id}}",
							"host": ["{{base_url}}"],
							"path": ["v1", "files", "{{file_id}}"]
						},
						"description": "Soft delete file (sets deleted_at timestamp)"
					},
					"response": []
				}
			],
			"description": "File upload lifecycle management"
		},
