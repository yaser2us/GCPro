{
  "info": {
    "name": "User Identity API",
    "description": "Postman collection for the User Identity pillar — device tokens, registration tokens, verification status, onboarding progress.\nBased on specs/user-identity/user-identity.pillar.v2.yml",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "admin_user_id", "value": "1" },
    { "key": "admin_user_role", "value": "admin" },
    { "key": "target_user_id", "value": "2" },
    { "key": "target_account_id", "value": "2" },
    { "key": "device_token_id", "value": "" },
    { "key": "registration_token_id", "value": "" }
  ],
  "item": [
    {
      "name": "1. Device Tokens",
      "item": [
        {
          "name": "1.1 Register Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id", "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{target_user_id}},\n  \"platform\": \"fcm\",\n  \"token\": \"eXaMpLeToKeN_FcM_0001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user-identity/device-tokens",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user-identity", "device-tokens"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('device_token_id', json.id);",
                  "  console.log('device_token_id set to', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Register Device Token (apns — second device)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id", "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{target_user_id}},\n  \"platform\": \"apns\",\n  \"token\": \"eXaMpLeToKeN_ApNs_0001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/user-identity/device-tokens",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user-identity", "device-tokens"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Revoke Device Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-id", "value": "{{admin_user_id}}" },
              { "key": "x-user-role", "value": "{{admin_user_role}}" }
            ],
            "body": { "mode": "raw", "raw": "" },
            "url": {
              "raw": "{{base_url}}/api/v1/user-identity/device-tokens/{{device_token_id}}/revoke",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user-identity", "device-tokens", "{{device_token_id}}", "revoke"]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({ key: 'Idempotency-Key', value: pm.variables.replaceIn('{{$guid}}') });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Status is revoked', () => pm.expect(json.status).to.eql('revoked'));"
                ]
              }
            }
          ]
        }
