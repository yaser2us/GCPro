              "mode": "raw",
              "raw": "{\n  \"code\": \"FRIEND_REFERRAL_2024\",\n  \"name\": \"Friend Referral Program 2024\",\n  \"reward_config\": {\n    \"referrer_reward\": {\n      \"type\": \"coins\",\n      \"amount\": 100\n    },\n    \"referee_reward\": {\n      \"type\": \"coins\",\n      \"amount\": 50\n    },\n    \"qualifying_action\": \"first_purchase\"\n  },\n  \"meta_json\": {\n    \"description\": \"Refer friends and earn coins!\"\n  }\n}"
