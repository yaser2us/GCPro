                "v1",
                "missions",
                "{{mission_id}}",
                "submissions",
                "{{submission_id}}",
                "approve"
              ]
            },
            "description": "Test approval with REVIEWER role (not just ADMIN).\n\nREVIEWER role has 'missions:review' permission."
          },
          "response": []
        },
