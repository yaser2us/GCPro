      "item": [
        {
          "name": "1. Publish Draft Mission (Success)",
          "id": "e93fa8a0-8853-43b4-9663-0b8307cd10c3",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{admin_user_id}}",
                "description": "Admin user ID"
              },
              {
                "key": "X-User-Role",
                "value": "ADMIN",
                "description": "User role (ADMIN, REVIEWER, USER)"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idempotency_key\": \"publish_test_{{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/missions/{{mission_id}}/publish",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "v1",
                "missions",
                "{{mission_id}}",
                "publish"
              ]
            },
            "description": "Publishes a draft mission.\n\n**Prerequisites:**\n- Mission must exist with status='DRAFT'\n- Mission must not be expired\n\n**Expected Response:**\n```json\n{\n  \"mission_id\": \"123e4567-e89b-12d3-a456-426614174000\",\n  \"status\": \"PUBLISHED\"\n}\n```"
          },
          "response": []
