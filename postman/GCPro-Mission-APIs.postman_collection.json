              },
              {
                "key": "X-User-Role",
                "value": "REVIEWER",
                "description": "REVIEWER role also has permission"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idempotency_key\": \"approve_test_{{$timestamp}}\",\n  \"approval_note\": \"Approved by reviewer\"\n}"
